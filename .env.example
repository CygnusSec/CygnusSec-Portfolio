# Example: Blog:/blog|Projects:/researches|Tags:/tags|About:/about
VITE_NAV_BUTTONS=Blog:/blog|Projects:/researches|Tags:/tags|About:/about

# Analytics (optional)
# VITE_GA_ID=G-XXXXXXXXXX

# ========================================
# NAVIGATION BUTTON EXAMPLES
# ========================================
# Copy one of these examples to your .env file

# ----------------------------------------
# Example 1: Default Configuration (Current)
# ----------------------------------------
# VITE_NAV_BUTTONS=Blog:/blog|Projects:/projects|Tags:/tags|About:/about

# ----------------------------------------
# Example 2: Add Contact Button
# ----------------------------------------
# VITE_NAV_BUTTONS=Blog:/blog|Projects:/projects|Tags:/tags|About:/about|Contact:/contact

# ----------------------------------------
# Example 3: Reordered (About First)
# ----------------------------------------
# VITE_NAV_BUTTONS=About:/about|Projects:/projects|Blog:/blog|Tags:/tags

# ----------------------------------------
# Example 4: Minimal (2 Buttons)
# ----------------------------------------
# VITE_NAV_BUTTONS=Blog:/blog|About:/about

# ----------------------------------------
# Example 5: Extended with Home
# ----------------------------------------
# VITE_NAV_BUTTONS=Home:/|Blog:/blog|Projects:/projects|Tags:/tags|About:/about|Contact:/contact

# ----------------------------------------
# Example 6: Custom Labels
# ----------------------------------------
# VITE_NAV_BUTTONS=Articles:/blog|My Work:/projects|Topics:/tags|Contact Me:/about

# ----------------------------------------
# Example 7: Portfolio Style
# ----------------------------------------
# VITE_NAV_BUTTONS=Home:/|Portfolio:/projects|About:/about|Contact:/contact

# ----------------------------------------
# Example 8: Blog Focus
# ----------------------------------------
# VITE_NAV_BUTTONS=Home:/|Articles:/blog|Categories:/tags|About:/about

# ----------------------------------------
# Example 9: Business Style
# ----------------------------------------
# VITE_NAV_BUTTONS=Home:/|Services:/services|Portfolio:/projects|Blog:/blog|Contact:/contact

# ----------------------------------------
# Example 10: Personal Site
# ----------------------------------------
# VITE_NAV_BUTTONS=About:/about|Projects:/projects|Blog:/blog|Resume:/resume

# ========================================
# NOTES:
# ========================================
# - Format: Label:path|Label:path|...
# - No spaces around : or |
# - Order matters (left to right)
# - Restart dev server after changes
# - Make sure routes exist in App.jsx
# ========================================

